rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'college']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 255 &&
             data.college is string && data.college.size() <= 200;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['title', 'price', 'category', 'condition', 'sellerId']) &&
             data.title is string && data.title.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.category is string && data.condition is string &&
             data.sellerId == request.auth.uid;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['chatId', 'senderId', 'receiverId', 'text', 'timestamp']) &&
             data.senderId == request.auth.uid &&
             data.text is string && data.text.size() <= 5000;
    }

    // Collection Rules
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // In a real app, we'd restrict user listing if privacy is a concern
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'college', 'avatar', 'rating']);
    }

    match /products/{productId} {
      allow read: if true; // Public marketplace
      allow create: if isSignedIn() && isEmailVerified() && isValidProduct(incoming()) && incoming().status == 'active';
      allow update: if isSignedIn() && (
        // Seller actions: update details or status
        (isOwner(existing().sellerId) && isValidProduct(incoming()) && 
         incoming().diff(existing()).affectedKeys().hasAny(['title', 'description', 'price', 'category', 'condition', 'images', 'status'])) ||
        // Buyer action: save item (add self to savedBy array)
        (incoming().diff(existing()).affectedKeys().hasOnly(['savedBy']) && incoming().status == existing().status)
      );
      allow delete: if isOwner(existing().sellerId);
    }

    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && request.auth.uid in incoming().participants && incoming().participants.size() == 2;
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants &&
                    incoming().diff(existing()).affectedKeys().hasAny(['lastMessage', 'lastTimestamp']);
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isSignedIn() && isValidMessage(incoming()) && 
                      request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }
  }
}
